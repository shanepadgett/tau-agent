{
	"name": "@shanepadgett/tau-agent",
	"version": "0.23.0",
	"description": "Tau is a custom agentic harness built with pi extensions",
	"type": "module",
	"main": "./src/index.ts",
	"types": "./src/index.ts",
	"exports": {
		".": "./src/index.ts"
	},
	"license": "MIT",
	"keywords": [
		"pi-package",
		"tau",
		"coding-agent"
	],
	"repository": {
		"type": "git",
		"url": "git+https://github.com/shanepadgett/tau-agent.git",
		"directory": "packages/agent"
	},
	"publishConfig": {
		"access": "public"
	},
	"files": [
		"src/**/*",
		"extensions/**/*",
		"shared/**/*",
		"prompts/**/*",
		"skills/**/*",
		"themes/**/*",
		"docs/**/*",
		"schemas/**/*",
		"README.md"
	],
	"dependencies": {
		"@shanepadgett/tau-tui": "0.23.0",
		"@toon-format/toon": "2.3.0",
		"image-size": "2.0.2",
		"smol-toml": "1.7.0"
	},
	"peerDependencies": {
		"@earendil-works/pi-ai": "*",
		"@earendil-works/pi-coding-agent": "*",
		"@earendil-works/pi-tui": "*",
		"typebox": "*"
	},
	"pi": {
		"extensions": [
			"./extensions/*/index.ts"
		],
		"skills": [
			"./skills"
		],
		"prompts": [
			"./prompts"
		],
		"themes": [
			"./themes"
		]
	},
	"engines": {
		"node": ">=22.19.0"
	}
}
