// lean: .pi/extensions/ are first-party consumers (per AGENTS.md). Fallow only
// descends into that dot dir because package.json scripts reference
// .pi/extensions/.fallow-scope.ts.
{
  "entry": [
    ".pi/extensions/*/index.ts",
    "packages/agent/extensions/*/index.ts",
		"packages/agent/src/index.ts",
    "packages/tui/src/index.ts",
    "packages/agent/scripts/generate-tau-schema.ts"
  ],
  "includeEntryExports": true,
  "ignorePatterns": [
    "packages/agent/shared/description.ts",
    "packages/agent/shared/injected-context.ts"
  ],
  "ignoreExports": [
    {
      "file": "packages/agent/extensions/*/index.ts",
      "exports": ["default"]
    },
    {
      "file": ".pi/extensions/*/index.ts",
      "exports": ["default"]
    }
  ],
  "usedClassMembers": [
    { "implements": "Component", "members": ["handleInput", "invalidate"] },
    { "implements": "Focusable", "members": ["focused"] }
  ]
}
