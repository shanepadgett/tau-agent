{
	"name": "tau-agent-monorepo",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"description": "Tau Agent monorepo",
	"license": "MIT",
	"packageManager": "npm@11.16.0",
	"devEngines": {
		"packageManager": {
			"name": "npm",
			"version": "11.16.0",
			"onFail": "error"
		}
	},
	"workspaces": [
		"packages/*"
	],
	"scripts": {
		"check:package-sources": "node --experimental-strip-types packages/agent/scripts/check-package-sources.ts",
		"fallow:pi-scope": "node --experimental-strip-types .pi/extensions/.fallow-scope.ts",
		"test:unit": "vitest --run --reporter=agent"
	},
	"pi": {
		"extensions": [
			"./packages/agent/extensions/*/index.ts"
		],
		"skills": [
			"./packages/agent/skills"
		],
		"prompts": [
			"./packages/agent/prompts"
		],
		"themes": [
			"./packages/agent/themes"
		]
	},
	"devDependencies": {
		"@earendil-works/pi-ai": "0.80.9",
		"@earendil-works/pi-coding-agent": "0.80.9",
		"@earendil-works/pi-tui": "0.80.9",
		"@types/node": "22.19.19",
		"@typescript/native-preview": "7.0.0-dev.20260120.1",
		"oxfmt": "0.57.0",
		"oxlint": "1.72.0",
		"typebox": "1.1.38",
		"typescript": "5.9.3",
		"vitest": "4.1.9"
	},
	"engines": {
		"node": ">=22.19.0"
	}
}
