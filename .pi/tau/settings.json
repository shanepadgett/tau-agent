{
	"$schema": "../../packages/agent/schemas/tau.schema.json",
	"extensions": {
		"reference": {
			"editor": "code"
		},
		"context": {
			"validation": {
				"ignoreGlobs": [
					"docs/plans/**",
					"packages/agent/native-bin/**"
				]
			}
		},
		"silentCommandRunner": {
			"commands": [
				{
					"name": "ts-check",
					"command": "mise run check:ts",
					"details": "Runs Tau schema drift check, Oxfmt formatting, Oxlint lint fixes, TypeScript (tsgo) checks, unit tests, and Fallow dead-code/duplication checks.",
					"includeGlobs": [
						"packages/**/*.ts",
						".pi/extensions/**/*.ts",
						"package.json",
						"package-lock.json",
						"tsconfig.json",
						"mise.toml",
						".oxfmtrc.jsonc",
						".oxlintrc.jsonc"
					]
				},
				{
					"name": "md-check",
					"command": "mise run check:md",
					"details": "Runs Markdown linting and fixes through markdownlint-cli2.",
					"includeGlobs": [
						"**/*.md"
					]
				}
			]
		}
	}
}
