{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"$id": "https://raw.githubusercontent.com/shanepadgett/tau-agent/refs/heads/main/schemas/tau.schema.json",
	"title": "Tau Configuration",
	"description": "Configuration for Tau and Tau extensions.",
	"type": "object",
	"properties": {
		"$schema": {
			"type": "string",
			"description": "Optional schema reference used by editors for validation and autocomplete."
		},
		"extensions": {
			"type": "object",
			"properties": {
				"footer": {
					"type": "object",
					"properties": {
						"enabled": {
							"type": "boolean",
							"default": true,
							"description": "Enable Tau's compact footer."
						}
					},
					"additionalProperties": false
				},
				"modelFallback": {
					"type": "object",
					"properties": {
						"cooldowns": {
							"type": "object",
							"patternProperties": {
								"^.*$": {
									"type": "number",
									"description": "Unix epoch milliseconds when the provider becomes available again."
								}
							}
						}
					},
					"additionalProperties": false
				},
				"reference": {
					"type": "object",
					"properties": {
						"editor": {
							"anyOf": [
								{
									"type": "string",
									"const": "default"
								},
								{
									"type": "string",
									"const": "code"
								},
								{
									"type": "string",
									"const": "zed"
								}
							],
							"default": "default",
							"description": "Editor used by the reference picker open action. default uses $VISUAL, $EDITOR, then code."
						}
					},
					"additionalProperties": false
				},
				"silentCommandRunner": {
					"type": "object",
					"properties": {
						"enabled": {
							"type": "boolean",
							"default": true,
							"description": "Enable silent command runner."
						},
						"maxOutputBytes": {
							"type": "integer",
							"default": 51200,
							"minimum": 1,
							"description": "Maximum raw stdout/stderr bytes sent to the agent."
						},
						"commands": {
							"type": "array",
							"items": {
								"type": "object",
								"required": [
									"name",
									"command"
								],
								"properties": {
									"name": {
										"type": "string",
										"description": "Short command name shown in notifications and failure messages."
									},
									"enabled": {
										"type": "boolean",
										"default": true,
										"description": "Enable this command."
									},
									"command": {
										"type": "string",
										"description": "Shell command run with sh -lc after matching files change."
									},
									"cwd": {
										"type": "string",
										"default": ".",
										"description": "Command working directory, relative to project root."
									},
									"env": {
										"type": "object",
										"patternProperties": {
											"^.*$": {
												"type": "string"
											}
										},
										"description": "Extra environment values."
									},
									"details": {
										"type": "string",
										"description": "Free-text explanation of what this command checks or runs."
									},
									"includeGlobs": {
										"type": "array",
										"items": {
											"type": "string"
										},
										"default": [
											"**/*"
										],
										"description": "Project-relative files that trigger this command."
									},
									"excludeGlobs": {
										"type": "array",
										"items": {
											"type": "string"
										},
										"default": [],
										"description": "Project-relative files ignored for this command."
									},
									"timeoutMs": {
										"type": "integer",
										"default": 120000,
										"minimum": 1,
										"description": "Command timeout in milliseconds."
									}
								},
								"additionalProperties": false
							},
							"default": [],
							"description": "Commands run after matched files change."
						}
					},
					"additionalProperties": false
				},
				"soul": {
					"type": "object",
					"properties": {
						"enabled": {
							"type": "boolean",
							"default": true,
							"description": "Enable Tau's Rok system prompt and slash-command modes."
						}
					},
					"additionalProperties": false
				}
			},
			"additionalProperties": true,
			"default": {}
		}
	},
	"additionalProperties": false
}
